{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audio Visualizer Widget",
  "version": "0.1.0",
  "identifier": "com.codex.audio-visualizer-widget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Audio Visualizer Widget",
        "width": 720,
        "height": 180,
        "minWidth": 320,
        "minHeight": 120,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis"
  }
}
